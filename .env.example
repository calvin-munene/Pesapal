# Pesapal API credentials (required)
# Get these from your Pesapal merchant account: https://developer.pesapal.com
PESAPAL_CONSUMER_KEY=
PESAPAL_CONSUMER_SECRET=

# Pesapal environment: "sandbox" for testing, "production" for live payments (required)
PESAPAL_ENV=

# PostgreSQL database connection string (required)
# Example: postgres://user:password@host:5432/dbname
DATABASE_URL=

# Server port (optional, defaults to 5000)
PORT=
